# API Configuration (Copy to .env and fill with your actual keys)
# IMPORTANT: Never commit .env file with real keys!

# ══════════════════════════════════════════════════════
# US 주식 API (우선순위순)
# ══════════════════════════════════════════════════════

# Finnhub (US 1순위 - 무료 60회/분)
# 발급: https://finnhub.io/register → 무료 API Key 즉시 발급
FINNHUB_API_KEY=your_finnhub_api_key_here

# FMP - Financial Modeling Prep (US 2순위 - 무료 250회/일)
# 발급: https://site.financialmodelingprep.com/developer
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage (폐기 - 하루 25회 한도로 부적합)
# ALPHA_VANTAGE_API_KEY=deprecated

# ══════════════════════════════════════════════════════
# KR 주식 API (우선순위순)
# ══════════════════════════════════════════════════════

# KRX Open API (KR 1순위 - 무료 10,000회/일)
# 발급: https://www.data.go.kr → 회원가입 → "주식시세정보" 검색 → 활용신청
KRX_API_KEY=your_krx_api_key_here

# DART OpenAPI (KR 2순위 - 재무제표/펀더멘탈)
# 발급: https://opendart.fss.or.kr → 회원가입 → 인증키 신청
DART_API_KEY=your_dart_api_key_here

# 한국투자증권 (KR 폴백 - 사용자 키 필요)
# 발급: https://apiportal.koreainvestment.com
KOR_INVESTMENT_APP_KEY=your_key_here
KOR_INVESTMENT_SECRET=your_secret_here
KOR_INVESTMENT_ACCOUNT=12345678

# ══════════════════════════════════════════════════════
# 광고 (배포 시 필수)
# ══════════════════════════════════════════════════════

# Google AdMob
ADMOB_BANNER_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxxxxxxxxxxxxx/xxxxxxxxxx
